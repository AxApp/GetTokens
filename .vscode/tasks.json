{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "GetTokens: Run App",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/wails-cli.sh",
      "args": [
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "GetTokens: Build App",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/wails-cli.sh",
      "args": [
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
